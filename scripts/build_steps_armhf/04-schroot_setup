set -x
STEP_DESCRIPTION="Setup schroot"
source "$(dirname $0)/../build_common"


#FIXME: parametrize nameserver addition
echo "nameserver 8.8.8.8" >> /var/chroot/buildroot/etc/resolv.conf

# Install necessary packages
chroot  /var/chroot/buildroot apt_update
chroot  /var/chroot/buildroot apt_install -y gnupg build-essential pkg-config nano wget python3 python3-pip python3-dev 

# Add raspberry pi sources
cat << EOF > /var/chroot/buildroot/etc/apt/sources.list.d/raspi.sources
Types: deb deb-src
URIs: http://archive.raspberrypi.com/debian/
Suites: ${DEBOOTSTRAP_TARGET}
Components: main
Architectures: ${RPI_APT_ARCH}
Signed-By: /usr/share/keyrings/raspberrypi-archive-keyring.pgp
EOF

# Fetch the latest raspberrypi-archive-keyring .deb and install it in the chroot
RPI_KEYRING_URL="https://archive.raspberrypi.com/debian/pool/main/r/raspberrypi-archive-keyring"
RPI_KEYRING_DEB=$(retry curl -4 -fSL --connect-timeout 5 --max-time 20 --retry 5 --retry-all-errors --retry-delay 1 "${RPI_KEYRING_URL}/" \
    | grep -oP 'raspberrypi-archive-keyring_[^"]+_all\.deb' | sort -V | tail -1)
retry curl -4 -fSL --connect-timeout 5 --max-time 20 --retry 5 --retry-all-errors --retry-delay 1 "${RPI_KEYRING_URL}/${RPI_KEYRING_DEB}" -o "/tmp/${RPI_KEYRING_DEB}"
cp "/tmp/${RPI_KEYRING_DEB}" "/var/chroot/buildroot/tmp/${RPI_KEYRING_DEB}"
chroot /var/chroot/buildroot dpkg -i "/tmp/${RPI_KEYRING_DEB}"


chroot  /var/chroot/buildroot apt_update
if [ $DEBOOTSTRAP_TARGET == "bullseye" ]
then
    chroot  /var/chroot/buildroot apt_install --no-install-recommends -y raspberrypi-kernel-headers 
elif [ $DEBOOTSTRAP_TARGET == "bookworm" -o $DEBOOTSTRAP_TARGET == "trixie" ]
then
    for khdrpkg in "${RPI_KERNEL_HDR_VERSIONS[@]}"
    do
        chroot  /var/chroot/buildroot apt_install --no-install-recommends -y ${khdrpkg}
    done
else
    echo "Unhandled target $DEBOOTSTRAP_TARGET"
    exit 1
fi


# Create schroot profile
cat > /etc/schroot/chroot.d/buildroot  << EOF
[buildroot]
description=ER buildroot for uniform builds ($RPI_APT_ARCH)
directory=/var/chroot/buildroot
root-users=root,crossbuilder
users=root,crossbuilder
type=directory
EOF