set -x
set -Eeuo pipefail

STEP_DESCRIPTION="Debootstrap buildroot"
source "$(dirname "$0")/../build_common"

apt_install -y --no-install-recommends   gpgv gnupg ca-certificates wget

mkdir -p /var/chroot/ /usr/share/keyrings /tmp/dbcache
rm -rf /var/chroot/buildroot /tmp/dbcache
mkdir -p /tmp/dbcache

# Fetch + dearmor key atomically
tmp_key="$(mktemp)"
wget -qO- "${DEBOOTSTRAP_SOURCE}/raspbian.public.key" | gpg --dearmor > "${tmp_key}"
install -m 0644 "${tmp_key}" /usr/share/keyrings/raspbian-archive-keyring.gpg
rm -f "${tmp_key}"

# Optional: show key fingerprint in logs (helps debugging key rotations)
gpg --show-keys --with-fingerprint /usr/share/keyrings/raspbian-archive-keyring.gpg | sed -n '1,20p' || true

# If this ever fails again, dump evidence
if ! debootstrap \
    --arch="${RPI_APT_ARCH}" \
    --cache-dir=/tmp/dbcache \
    --keyring=/usr/share/keyrings/raspbian-archive-keyring.gpg \
    --verbose --foreign --variant=buildd \
    "${DEBOOTSTRAP_TARGET}" /var/chroot/buildroot \
    "${DEBOOTSTRAP_SOURCE}/raspbian/"
then
  env | grep -i proxy || true
  find /tmp/dbcache -maxdepth 5 -type f -iname 'InRelease' -print -exec head -n 5 {} \; || true
  if command -v gpgv >/dev/null; then
    find /tmp/dbcache -maxdepth 5 -type f -iname 'InRelease' -print -exec \
      gpgv -vv --keyring /usr/share/keyrings/raspbian-archive-keyring.gpg {} \; || true
  fi
  exit 1
fi

chroot /var/chroot/buildroot /debootstrap/debootstrap --second-stage

cp /usr/local/bin/retry /var/chroot/buildroot/usr/local/bin/retry
cp /usr/local/bin/apt_update /var/chroot/buildroot/usr/local/bin/apt_update
cp /usr/local/bin/apt_install /var/chroot/buildroot/usr/local/bin/apt_install
chmod 0755 /var/chroot/buildroot/usr/local/bin/retry
chmod 0755 /var/chroot/buildroot/usr/local/bin/apt_update
chmod 0755 /var/chroot/buildroot/usr/local/bin/apt_install
